# ============================================================
# SPECTROLITE — DEGENERATE GAMBIT  |  Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# Fill in every value before running. Never commit .env to git.

# ── Padre Terminal Credentials (AES-encrypted blob, base64) ──
PADRE_CREDENTIALS_ENCRYPTED=

# ── Telegram Notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notification Email (for SOBRIETY MODE autopsy report) ────
USER_EMAIL=

# ── Blockchain APIs ──────────────────────────────────────────
BIRDEYE_API_KEY=
NANSEN_API_KEY=
BLOXROUTE_API_KEY=
CHAINLINK_RPC_URL=

# ── Solana RPC ───────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ── EVM RPC Endpoints ────────────────────────────────────────
ETHEREUM_RPC_URL=
BASE_RPC_URL=
BNB_RPC_URL=

# ── Wallet Private Keys (encrypted, never plaintext) ─────────
WALLET_ENCRYPTION_KEY=
WALLET_1_ENCRYPTED=
WALLET_2_ENCRYPTED=
WALLET_3_ENCRYPTED=
WALLET_4_ENCRYPTED=
WALLET_5_ENCRYPTED=

# ── Social Scraping ──────────────────────────────────────────
APIFY_API_TOKEN=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spectrolite-degen-bot/2.0

# ── AI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# ── Infrastructure ───────────────────────────────────────────
DATABASE_URL=postgresql://spectrolite:changeme@localhost:5432/degenerate_gambit
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-to-a-long-random-string

# ── Foundry Anvil Fork (for honeypot simulation) ─────────────
ANVIL_FORK_URL=https://api.mainnet-beta.solana.com
ANVIL_PORT=8545

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme

# ── Email (SOBRIETY MODE PDF delivery) ───────────────────────
